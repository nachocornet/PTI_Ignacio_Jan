# Minimal .env example for local development
# For full reference, see config/.env.complete.example

# Blockchain network (local | sepolia)
SSI_BLOCKCHAIN_NETWORK=local

# Ports
SSI_ISSUER_PORT=5010
SSI_VERIFIER_PORT=5011
SSI_FRONTEND_PORT=8080

# Database (local SQLite by default)
# DATABASE_URL=postgresql+psycopg2://user:password@host/db

# Admin credentials
SSI_ADMIN_USER=admin
SSI_ADMIN_PASSWORD=admin123

# For Sepolia testnet (optional)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
