# ============================================================================
# SSI v2 - Configuración Completa de Entorno
# ============================================================================
# Este archivo contiene TODAS las variables de configuración disponibles.
# Usa este como referencia cuando necesites customizar tu despliegue.
#
# Para despliegue LOCAL: copia este archivo a `.env` y comenta las vars de VMs
# Para despliegue en VMSVIRTECH: las vars de VM se inyectan automáticamente
# ============================================================================

# ============================================================================
# 1. CONFIGURACIÓN DE RED (Aplicable a local y VM)
# ============================================================================

# Host donde escucha la app (local)
SSI_APP_HOST=127.0.0.1

# Host donde vincula la app en Docker (normalmente 0.0.0.0 en contenedor)
SSI_APP_BIND_HOST=0.0.0.0

# Puerto del servicio Issuer
SSI_ISSUER_PORT=5010

# Puerto del servicio Verifier
SSI_VERIFIER_PORT=5011

# Puerto del servidor frontend
SSI_FRONTEND_PORT=8080

# ============================================================================
# 2. CONFIGURACIÓN DE BLOCKCHAIN (Desarrollo vs Producción)
# ============================================================================

# Red blockchain: "local" o "sepolia"
# - local: Hardhat en localhost:8545 (despliegue automático cada vez)
# - sepolia: Red Sepolia (requiere RPC URL y contrato predeployado)
SSI_BLOCKCHAIN_NETWORK=local

# Host del nodo blockchain (solo si SSI_BLOCKCHAIN_NETWORK=local)
SSI_BLOCKCHAIN_HOST=127.0.0.1

# Puerto del nodo blockchain (solo si SSI_BLOCKCHAIN_NETWORK=local)
SSI_BLOCKCHAIN_PORT=8545

# URL RPC de Sepolia (obligatorio si SSI_BLOCKCHAIN_NETWORK=sepolia)
# Ejemplos:
#   - https://sepolia.infura.io/v3/YOUR_PROJECT_ID
#   - https://sepolia.drpc.org
SEPOLIA_RPC_URL=

# ============================================================================
# 3. ARCHIVOS Y PERSISTENCIA
# ============================================================================

# Path al wallet del Issuer (emisor de credenciales)
SSI_ISSUER_WALLET_FILE=deployments/runtime/issuer_wallet.json

# Path al wallet del Holder (titular de credenciales)
SSI_HOLDER_WALLET_FILE=deployments/runtime/wallet.json

# Path al artefacto del contrato inteligente
# Determina automáticamente según SSI_BLOCKCHAIN_NETWORK si no se especifica
SSI_CONTRACT_FILE=deployments/blockchain_contract.json

# ============================================================================
# 4. POLÍTICA DE CORS (Control de Acceso)
# ============================================================================

# Orígenes permitidos (comma-separated o "*" para todos)
# Recomendado: especificar explícitamente en producción
# SSI_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,https://tu-dominio.com

# ============================================================================
# 5. BASE DE DATOS (PostgreSQL en producción)
# ============================================================================

# URL de conexión PostgreSQL
# Formato: postgresql+psycopg2://usuario:contraseña@host:puerto/database
# Si no está set: usa SQLite local en deployments/runtime/ssi_sessions.db
# DATABASE_URL=postgresql+psycopg2://ssi_user:change_me@db:5432/ssi_db

# ============================================================================
# 6. INFRAESTRUCTURA VIRTECH / OpenNebula (Solo para despliegue remoto)
# ============================================================================

# Host de las VMs (nombre o IP)
# NATTECH_HOST=nattech.fib.upc.edu

# Usuario SSH para acceso a las VMs
# SSH_USER=alumne

# Ruta de despliegue en las VMs
# DEPLOY_PATH=/home/alumne/pti-v2

# Puertos SSH por NAT (cada VM tiene un puerto diferente)
# FRONTEND_SSH_PORT=40561
# BACKEND_SSH_PORT=40571
# DB_SSH_PORT=40581

# Password de PostgreSQL en VM
# DB_PASSWORD=

# RPC de Sepolia (para backend en VM)
# SEPOLIA_RPC_URL=

# Base64 del wallet del Issuer (para inyectar en backend VM)
# ISSUER_WALLET_JSON_B64=

# ============================================================================
# 7. URLs EXTERNAS (Para acceso desde fuera de las VMs)
# ============================================================================

# URL base del Frontend (como la ven los usuarios)
# FRONTEND_EXTERNAL_URL=http://nattech.fib.upc.edu:40560

# URL base del Backend (como la ven los usuarios)
# BACKEND_EXTERNAL_URL=http://nattech.fib.upc.edu:40570

# ============================================================================
# 8. USUARIO Y BASE DE DATOS (PostgreSQL)
# ============================================================================

# Usuario PostgreSQL
# POSTGRES_USER=ssi_user

# Nombre de la base de datos
# POSTGRES_DB=ssi_db

# Password PostgreSQL
# POSTGRES_PASSWORD=

# ============================================================================
# EJEMPLOS DE CONFIGURACIÓN COMPLETA
# ============================================================================

# Ejemplo 1: Desarrollo Local Completo
# SSI_APP_HOST=127.0.0.1
# SSI_APP_BIND_HOST=0.0.0.0
# SSI_ISSUER_PORT=5010
# SSI_VERIFIER_PORT=5011
# SSI_FRONTEND_PORT=8080
# SSI_BLOCKCHAIN_NETWORK=local
# SSI_BLOCKCHAIN_HOST=127.0.0.1
# SSI_BLOCKCHAIN_PORT=8545
# SSI_ISSUER_WALLET_FILE=deployments/runtime/issuer_wallet.json
# SSI_HOLDER_WALLET_FILE=deployments/runtime/wallet.json

# Ejemplo 2: Local con PostgreSQL
# DATABASE_URL=postgresql+psycopg2://ssi_user:password@localhost:5432/ssi_db
# SSI_BLOCKCHAIN_NETWORK=local

# Ejemplo 3: Producción Sepolia
# SSI_BLOCKCHAIN_NETWORK=sepolia
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# SSI_CONTRACT_FILE=deployments/blockchain_contract.sepolia.json
# DATABASE_URL=postgresql+psycopg2://ssi_user:secure_password@db-host:5432/ssi_db
# SSI_CORS_ORIGINS=https://tu-dominio.com

# ============================================================================
# NOTAS DE SEGURIDAD
# ============================================================================
# 
# 1. NUNCA comitees credenciales reales (passwords, RPC URLs, claves privadas)
# 2. Usa GitHub Secrets para CI/CD
# 3. En producción, carga valores desde vault/secrets manager
# 4. SSI_ISSUER_WALLET_FILE debe estar protegido (no exponer en frontend)
# 5. DATABASE_URL contiene credenciales: protege acceso al archivo .env
#
# ============================================================================
